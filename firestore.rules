rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function isEditor() {
      return isAuthenticated() && (getUserData().role == 'editor' || getUserData().role == 'admin');
    }

    function isViewer() {
      return isAuthenticated() && (
        getUserData().role == 'viewer' ||
        getUserData().role == 'editor' ||
        getUserData().role == 'admin'
      );
    }

    function userOrgId() {
      return getUserData().orgId;
    }

    function sameOrg(docOrgId) {
      return isAuthenticated() && docOrgId == userOrgId();
    }

    // Organizations collection
    match /organizations/{orgId} {
      // Any authenticated user can read an org (needed to validate invite codes)
      allow read: if isAuthenticated();
      // Only authenticated users can create orgs
      allow create: if isAuthenticated();
      // Only admins of the same org can update
      allow update: if isAdmin() && sameOrg(resource.data.orgId);
      allow delete: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (
        request.auth.uid == userId ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Transactions collection — org-isolated
    match /transactions/{transactionId} {
      allow read: if isViewer() && sameOrg(resource.data.orgId);
      allow create: if isEditor() && request.resource.data.orgId == userOrgId();
      allow update: if isEditor() && sameOrg(resource.data.orgId);
      allow delete: if isEditor() && sameOrg(resource.data.orgId);
    }

    // Entities collection — org-isolated
    match /entities/{entityId} {
      allow read: if isViewer() && sameOrg(resource.data.orgId);
      allow create: if isAdmin() && request.resource.data.orgId == userOrgId();
      allow update: if isAdmin() && sameOrg(resource.data.orgId);
      allow delete: if isAdmin() && sameOrg(resource.data.orgId);
    }

    // Categories collection — org-isolated
    match /categories/{categoryId} {
      allow read: if isViewer() && sameOrg(resource.data.orgId);
      allow create: if isAdmin() && request.resource.data.orgId == userOrgId();
      allow update: if isAdmin() && sameOrg(resource.data.orgId);
      allow delete: if isAdmin() && sameOrg(resource.data.orgId);
    }

    // User Logs collection — org-isolated
    match /userLogs/{logId} {
      allow read: if isAdmin() && sameOrg(resource.data.orgId);
      allow create: if isAuthenticated() && request.resource.data.orgId == userOrgId();
      allow update, delete: if false;
    }

    // EMI Loans collection — org-isolated
    match /emiLoans/{loanId} {
      allow read: if isViewer() && sameOrg(resource.data.orgId);
      allow create: if isEditor() && request.resource.data.orgId == userOrgId();
      allow update: if isEditor() && sameOrg(resource.data.orgId);
      allow delete: if isEditor() && sameOrg(resource.data.orgId);
    }
  }
}
