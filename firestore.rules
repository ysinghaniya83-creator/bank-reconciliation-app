rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function isEditor() {
      return isAuthenticated() && (getUserData().role == 'editor' || getUserData().role == 'admin');
    }

    function isViewer() {
      return isAuthenticated() && (
        getUserData().role == 'viewer' ||
        getUserData().role == 'editor' ||
        getUserData().role == 'admin'
      );
    }

    function userOrgId() {
      return getUserData().orgId;
    }

    function sameOrg(docOrgId) {
      return isAuthenticated() && docOrgId == userOrgId();
    }

    // Orphaned doc = existed before multi-tenant, has no orgId yet
    function isOrphaned() {
      return !('orgId' in resource.data);
    }

    // Organizations collection — doc ID is the orgId, so no orgId field on the doc itself
    match /organizations/{orgId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() && orgId == userOrgId();
      allow delete: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Transactions collection — org-isolated, admins can migrate orphaned docs
    match /transactions/{transactionId} {
      allow read: if (isViewer() && sameOrg(resource.data.orgId))
                  || (isAdmin() && isOrphaned());
      allow create: if isEditor() && request.resource.data.orgId == userOrgId();
      allow update: if (isEditor() && sameOrg(resource.data.orgId))
                  || (isAdmin() && isOrphaned());
      allow delete: if isEditor() && sameOrg(resource.data.orgId);
    }

    // Entities collection — org-isolated, admins can migrate orphaned docs
    match /entities/{entityId} {
      allow read: if (isViewer() && sameOrg(resource.data.orgId))
                  || (isAdmin() && isOrphaned());
      allow create: if isAdmin() && request.resource.data.orgId == userOrgId();
      allow update: if (isAdmin() && sameOrg(resource.data.orgId))
                  || (isAdmin() && isOrphaned());
      allow delete: if isAdmin() && sameOrg(resource.data.orgId);
    }

    // Categories collection — org-isolated, admins can migrate orphaned docs
    match /categories/{categoryId} {
      allow read: if (isViewer() && sameOrg(resource.data.orgId))
                  || (isAdmin() && isOrphaned());
      allow create: if isAdmin() && request.resource.data.orgId == userOrgId();
      allow update: if (isAdmin() && sameOrg(resource.data.orgId))
                  || (isAdmin() && isOrphaned());
      allow delete: if isAdmin() && sameOrg(resource.data.orgId);
    }

    // User Logs collection — org-isolated, admins can migrate orphaned docs
    match /userLogs/{logId} {
      allow read: if (isAdmin() && sameOrg(resource.data.orgId))
                  || (isAdmin() && isOrphaned());
      allow create: if isAuthenticated() && request.resource.data.orgId == userOrgId();
      allow update, delete: if false;
    }

    // EMI Loans collection — org-isolated, admins can migrate orphaned docs
    match /emiLoans/{loanId} {
      allow read: if (isViewer() && sameOrg(resource.data.orgId))
                  || (isAdmin() && isOrphaned());
      allow create: if isEditor() && request.resource.data.orgId == userOrgId();
      allow update: if (isEditor() && sameOrg(resource.data.orgId))
                  || (isAdmin() && isOrphaned());
      allow delete: if isEditor() && sameOrg(resource.data.orgId);
    }
  }
}
